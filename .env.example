# InBody Dashboard webhook
# Where to forward completed workouts.
INBODY_WEBHOOK_URL=https://inbody-to-garmin.vercel.app/api/lifting/workouts
# Server-side bearer token. NEVER expose to the browser.
# Mint at https://inbody-to-garmin.vercel.app/settings/lifting
INBODY_INGEST_TOKEN=

# These are read by:
#   • api/inbody-push.js  (Vercel serverless function — proxies live workout pushes)
#   • scripts/backfill-inbody.mjs  (one-shot backfill from Firestore)
#
# In production, also set both as Project Environment Variables in Vercel.
